# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# beats (generated audio)
*.wav
apps/*/node_modules/

# iOS app secrets (per-app Secrets.swift is generated from Secrets.swift.example)
apps/*/*/Secrets.swift

# Python virtualenvs under scripts/
scripts/*/.venv/
scripts/*/__pycache__/

# Xcode build artifacts
apps/*/build/
apps/*/DerivedData/
apps/*/*/DerivedData/
apps/*/*.xcodeproj/xcuserdata/
apps/*/*.xcodeproj/project.xcworkspace/xcuserdata/
