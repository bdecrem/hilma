import Foundation

// Copy this file to Secrets.swift and fill in the values.
// Secrets.swift is gitignored.

enum Backend {
    case local   // hilma dev server via tunn3l
    case vercel  // hilma production
}

enum Secrets {
    /// `.local` hits `pnpm dev` via tunn3l; `.vercel` hits prod.
    static let backend: Backend = .local

    /// Must match FEYND_SHARED_SECRET on the chosen backend.
    static let backendSecret = "REPLACE_ME"

    /// Optional stable device ID override. Leave empty to generate a random
    /// UUID stored in the Keychain. Set to a string to pin the device ID
    /// (useful for seeding content you want to tie to a specific phone).
    static let deviceIdOverride = ""

    static var backendBaseURL: URL {
        switch backend {
        case .local:  return URL(string: "https://bart-imac.tunn3l.sh")!
        case .vercel: return URL(string: "https://hilma-nine.vercel.app")!
        }
    }
}
