import Foundation

// Copy this file to Secrets.swift and fill in the values.
// Secrets.swift is gitignored.
//
// Model/API keys live server-side on the hilma backend. The app only
// carries the backend URL and a shared bearer.

enum Backend {
    case local   // hilma dev server reached via tunn3l (works on Simulator + device)
    case vercel  // production hilma deploy
}

enum Secrets {
    /// Flip this to route the app at a different backend.
    static let backend: Backend = .local

    /// Must match LEARNAI_SHARED_SECRET on the chosen backend.
    static let backendSecret = "REPLACE_ME"

    static var backendBaseURL: URL {
        switch backend {
        case .local:  return URL(string: "https://bart-imac.tunn3l.sh")!
        case .vercel: return URL(string: "https://hilma-nine.vercel.app")!
        }
    }
}
