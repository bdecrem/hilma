import Foundation

// Copy this file to Secrets.swift and fill in the values.
// Secrets.swift is gitignored.
//
// The app no longer holds OpenAI or Anthropic keys directly — those live
// server-side in the hilma backend. The only secret the app carries is the
// shared bearer for the LearnAI endpoints.
enum Secrets {
    /// Base URL of the hilma backend. Use the Vercel production URL in release,
    /// your tunn3l subdomain (e.g. https://bart-imac.tunn3l.sh) for local dev.
    static let backendBaseURL = URL(string: "https://hilma-nine.vercel.app")!

    /// Matches LEARNAI_SHARED_SECRET in the hilma .env.local / Vercel env vars.
    static let backendSecret = "REPLACE_ME"
}
